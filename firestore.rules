// Firestore rules for the MANAGED (hosted-service) deployment — see OPERATORS.md.
// Requires sign-in and per-space membership; the events history is append-only
// at the server. (Self-hosted households use the simpler rules in the README.)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // OPERATOR allowlist — put your own Firebase Auth UID(s) here to unlock the
    // dashboard (Settings → your account → copy UID, or Firebase console → Auth).
    function isOperator() {
      return request.auth != null && request.auth.uid in [
        'REPLACE_WITH_YOUR_OPERATOR_UID'
      ];
    }

    // cohort + first-party analytics (v37/v39): each user writes only their own
    // doc; the operator may read them all for the dashboard, but never write.
    match /cohorts/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) || isOperator();
      allow write: if request.auth != null && request.auth.uid == uid;
      allow list: if isOperator();
    }
    // operator-only read of usage counters across the AI proxy
    match /aiQuota/{uid} {
      allow read, list: if isOperator();
      // (writes happen server-side in the Cloud Function via the Admin SDK)
    }

    match /households/{hid} {

      function isMember() {
        return request.auth != null
          && get(/databases/$(database)/documents/households/$(hid)).data.members[request.auth.uid] is string;
      }

      // read the space doc: members only (list is never allowed → ids stay private)
      allow get: if request.auth != null
        && resource.data.members[request.auth.uid] is string;
      allow list: if false;

      // create: you must put yourself in the members map
      allow create: if request.auth != null
        && request.resource.data.members[request.auth.uid] is string;

      // update: members may edit; a NON-member may only add themself (joining)
      allow update: if request.auth != null && (
        resource.data.members[request.auth.uid] is string
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members.diff(resource.data.members).affectedKeys()
               .hasOnly([request.auth.uid])
        )
      );
      allow delete: if false;

      match /items/{item} {
        allow read, write: if isMember();
      }

      match /events/{event} {
        allow read, create: if isMember();
        allow update, delete: if false;   // append-only history, enforced server-side
      }

      match /receipts/{receipt} {
        allow read, create: if isMember();   // C1d (future): receipt thumbnails
        allow update, delete: if false;
      }
    }
  }
}
